        - name: POD_NAMESPACE
          valueFrom:
            fieldRef:
              fieldPath: metadata.namespace
        - name: POD_NAME
          valueFrom:
            fieldRef:
              fieldPath: metadata.name
        resources:
          requests:
            cpu: 100m
            memory: 128Mi
        args:
          
          - -nginx-plus=true
          - -nginx-reload-timeout=60000
          - -nginx-configmaps=$(POD_NAMESPACE)/daemonset-nginx-ingress
          - -mgmt-configmap=$(POD_NAMESPACE)/daemonset-nginx-ingress-mgmt
          - -ingress-class=nginx
          - -health-status=false
          - -health-status-uri=/nginx-health
          - -nginx-debug=false
          - -log-level=info
          - -log-format=glog
          - -enable-config-safety=false
          - -nginx-status=true
          - -nginx-status-port=8080
          - -nginx-status-allow-cidrs=127.0.0.1
          - -report-ingress-status
