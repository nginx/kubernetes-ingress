          - -nginx-status=true
          - -nginx-status-port=8080
          - -nginx-status-allow-cidrs=127.0.0.1
          - -report-ingress-status
          - -external-service=plus-mgmt-proxy-host-auth-nginx-ingress-controller
          - -enable-leader-election=true
          - -leader-election-lock-name=plus-mgmt-proxy-host-auth-nginx-ingress-leader-election
          - -enable-prometheus-metrics=true
