# syntax=docker/dockerfile:1.24
FROM redhat/ubi8@sha256:f2f9d7f22d8082e9b78d3b25dbc9c85300a335f8f9c0186352df2cf364bacb6b AS rpm-build
RUN mkdir -p /rpms/ \
    && dnf install rpm-build gcc make cmake -y \
    && rpmbuild --rebuild --nodebuginfo https://mirror.stream.centos.org/9-stream/BaseOS/source/tree/Packages/c-ares-1.19.1-2.el9.src.rpm \
    && cp /root/rpmbuild/RPMS/$(arch)/* /rpms/ \
    && rm -rf /rpms/*devel*

FROM scratch AS final
COPY --link --from=rpm-build /rpms /
